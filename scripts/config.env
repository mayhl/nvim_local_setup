#!/usr/env/bin bash

# Use INSTALL_ROOT for all tool installations if set, otherwise default to ~/.local/opt/nvim_stack
INSTALL_ROOT=${INSTALL_ROOT:-$HOME/.local/opt/nvim_stack}
INSTALL_PATH=$INSTALL_ROOT

BUILD_PATH=$INSTALL_ROOT/build
LOG_PATH=$INSTALL_ROOT/log

mkdir -p "$BUILD_PATH" "$LOG_PATH"

# Standardized Logging
setup_logging() {
    local script_name=$(basename "$0" .sh)
    LOG_FILE="$LOG_PATH/${script_name}.log"
    echo "--- Log started at $(date) ---" > "$LOG_FILE"
}

log_header() {
    echo "--------------------------"
    echo "Building $1"
    echo "--------------------------"
}

run_and_log() {
    local msg="$1"
    shift
    echo "$msg..."
    if "$@" >> "$LOG_FILE" 2>&1; then
        return 0
    else
        echo "Failed: $msg (see $LOG_FILE for details)" >&2
        return 1
    fi
}
